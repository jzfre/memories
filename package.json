{
  "name": "memories",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": { "node": ">=20" },
  "scripts": {
    "db:up": "docker compose up -d db",
    "db:down": "docker compose down",
    "generate": "pnpm --filter @memories/memory-gateway db:generate",
    "migrate": "pnpm --filter @memories/memory-gateway db:migrate",
    "scan": "pnpm --filter @memories/memory-gateway scan",
    "reembed": "pnpm --filter @memories/memory-gateway reembed",
    "rebuild": "pnpm --filter @memories/memory-gateway rebuild",
    "status": "pnpm --filter @memories/memory-gateway status",
    "audit:search": "pnpm --filter @memories/memory-gateway audit:search",
    "api": "pnpm --filter @memories/memory-gateway api",
    "mcp": "pnpm --filter @memories/memory-gateway mcp",
    "mcp:http": "pnpm --filter @memories/memory-gateway mcp:http",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
